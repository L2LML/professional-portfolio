# ── Source Database (PostgreSQL) ──────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=life_insurance_claims
PG_USER=postgres
PG_PASSWORD=your_password_here

# ── AWS (S3 Data Lake) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_BUCKET=insurance-claims-datalake
AWS_PREFIX=migrations/v1/

# ── Pipeline Settings ─────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
